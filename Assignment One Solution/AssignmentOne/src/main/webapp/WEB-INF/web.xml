<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <servlet>
        <servlet-name>GetAllCustomers_Servlet</servlet-name>
        <servlet-class>com.example.assignmentone.GetAllCustomers_Servlet</servlet-class>
        <load-on-startup>1</load-on-startup>
        <!-- The load-on-startup element with a positive integer value indicates the order in which the servlet should be loaded, 1 being the earliest -->
    </servlet>

    <servlet-mapping>
        <servlet-name>GetAllCustomers_Servlet</servlet-name>
        <url-pattern>/GetAllCustomers</url-pattern>
        <!-- Map the servlet to a URL pattern -->
    </servlet-mapping>

</web-app>